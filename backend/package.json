{
  "name": "banco-nexus-backend",
  "version": "1.0.0",
  "description": "API REST para Banco Nexus - Base de Datos Distribuida con Mongoose",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "init-db": "node seed.js",
    "dev": "nodemon server.js",
    "replica:init": "mongosh --port 27017 scripts/initializeReplicaSet.js",
    "replica:failover": "node scripts/failoverTest.js",
    "replica:stepdown": "node scripts/stepDownPrimary.js",
    "test": "node --test tests/*.test.js",
    "simulate-branches": "node scripts/simulateConcurrentBranches.js",
    "simulate-cdmx": "node scripts/cdmxBranchOperation.js",
    "simulate-gdl": "node scripts/gdlBranchOperation.js",
    "simulate-mty": "node scripts/mtyBranchOperation.js",
    "simulate-pue": "node scripts/pueBranchOperation.js",
    "simulate-tij": "node scripts/tijBranchOperation.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.2.0",
    "mongoose": "^9.6.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Banco Nexus - Equipo Distribuido",
  "license": "ISC"
}
